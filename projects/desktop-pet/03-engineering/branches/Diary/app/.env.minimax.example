# MiniMax preset example for Diary LLM boundary.
# Copy this into a private .env.local file or export it in your shell.
# Do not commit real keys. This one value is enough for the default MiniMax preset.

MINIMAX_API_KEY=${MINIMAX_API_KEY}

# Optional overrides. Leave commented unless you need to change defaults.
# DIARY_LLM_MODEL=MiniMax-M2.7
# DIARY_REACTION_MODEL=MiniMax-M2.7

# Optional voice overrides. The MiniMax preset already enables the server-side TTS bridge.
# DIARY_TTS_PROVIDER=http-json
# DIARY_TTS_ENDPOINT=${DIARY_TTS_ENDPOINT}
# DIARY_TTS_API_KEY=${DIARY_TTS_API_KEY}
# DIARY_TTS_VOICE=${DIARY_TTS_VOICE}
